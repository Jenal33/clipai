# ── DATABASE ──────────────────────────────────────────
DATABASE_URL=postgresql://clipai_user:***@localhost:5432/clipai_db

# ── REDIS ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── NEXTAUTH ──────────────────────────────────────────
NEXTAUTH_URL=https://clipai.up.railway.app
NEXTAUTH_SECRET=generate-with-node -e "crypto.randomBytes(32).toString('hex')"

# ── OWNER ACCESS ──────────────────────────────────────
OWNER_SECRET=dewa

# ── AI ────────────────────────────────────────────────
CHENZK_API_KEY=your-chenzk-api-key

# ── CLOUDFLARE R2 ─────────────────────────────────────
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=clipai-videos

# ── MIDTRANS ──────────────────────────────────────────
MIDTRANS_SERVER_KEY=Mid-server-your-key
MIDTRANS_CLIENT_KEY=Mid-client-your-key
MIDTRANS_IS_PRODUCTION=false

# ── TRIPAY ────────────────────────────────────────────
TRIPAY_API_KEY=your-tripay-key
TRIPAY_PRIVATE_KEY=your-tripay-private
TRIPAY_MERCHANT_CODE=your-merchant

# ── APP ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://clipai.up.railway.app
CORS_ORIGINS=https://clipai.up.railway.app
